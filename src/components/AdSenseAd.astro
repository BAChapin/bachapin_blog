---
interface Props {
  slot?: string;
  label?: string;
  class?: string;
}

const {
  slot,
  label = 'Advertisement',
  class: className = '',
} = Astro.props;

const enabled = import.meta.env.PUBLIC_ADSENSE_ENABLED === 'true';
const client = import.meta.env.PUBLIC_ADSENSE_CLIENT;
const shouldRender = enabled && client && slot;
---

{shouldRender && (
  <aside class:list={['not-prose border-y border-divider py-6', className]} aria-label={label}>
    <p class="mb-3 font-mono text-xs uppercase tracking-[0.14em] text-muted">{label}</p>
    <ins
      class="adsbygoogle block min-h-[120px] w-full"
      style="display:block"
      data-ad-client={client}
      data-ad-slot={slot}
      data-ad-format="auto"
      data-full-width-responsive="true"
    ></ins>
    <script is:inline>
      try {
        window.adsbygoogle = window.adsbygoogle || [];
        window.adsbygoogle.push({});
      } catch {
        // Ad blockers or script loading issues should never break the article page.
      }
    </script>
  </aside>
)}
