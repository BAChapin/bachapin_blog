---
import SocialLinks from '@/components/SocialLinks.astro';
---

<footer class="border-t border-divider px-6 py-8 sm:px-8">
  <div class="flex flex-col gap-3 text-sm text-muted sm:flex-row sm:items-center sm:justify-between">
    <p>&copy; {new Date().getFullYear()} Bachapin. Built with Astro.</p>
    <div class="flex flex-wrap gap-4">
      <SocialLinks variant="inline" />
      <a href="/rss.xml" class="font-mono hover:text-accent">RSS</a>
    </div>
  </div>
</footer>
