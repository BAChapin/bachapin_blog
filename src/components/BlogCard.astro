---
import { estimateReadingTime, formatDate, getPostSlug, type BlogPost } from '@/utils/posts';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const slug = getPostSlug(post);
const readingTime = estimateReadingTime(post.body);
---

<article class="border border-divider bg-surface p-6 transition-colors duration-200 hover:border-accent/70">
  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-sm text-muted">
    <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
    <span aria-hidden="true">/</span>
    <span>{readingTime}</span>
    {post.data.draft && <span class="text-accent">Draft</span>}
  </div>
  <h2 class="mt-4 text-2xl font-semibold leading-tight text-text">
    <a href={`/blog/${slug}`} class="hover:text-accent">{post.data.title}</a>
  </h2>
  <p class="mt-4 text-muted">{post.data.description}</p>
  {post.data.tags.length > 0 && (
    <div class="mt-6 flex flex-wrap gap-2" aria-label="Post tags">
      {post.data.tags.map((tag) => (
        <a
          href={`/blog?tag=${encodeURIComponent(tag)}`}
          class="font-mono text-sm text-muted hover:text-accent"
        >
          #{tag}
        </a>
      ))}
    </div>
  )}
</article>
