<section class="border border-divider bg-surface p-6">
  <p class="font-mono text-sm text-muted">Newsletter</p>
  <h2 class="mt-3 text-2xl font-semibold leading-tight text-text">Notes from the workbench</h2>
  <p class="mt-3 text-muted">
    Occasional essays on software, systems, and the habits that make good work sustainable.
  </p>
  <form class="mt-6 flex flex-col gap-3 sm:flex-row" action="#" method="post">
    <label class="sr-only" for="email">Email address</label>
    <input
      id="email"
      name="email"
      type="email"
      placeholder="you@example.com"
      autocomplete="email"
      class="min-h-11 flex-1 border border-divider bg-ink px-4 text-text placeholder:text-muted focus:border-accent focus:outline-none"
    />
    <button
      type="submit"
      class="min-h-11 border border-divider px-4 font-mono text-sm text-text transition-colors duration-200 hover:border-accent hover:text-accent"
    >
      Subscribe
    </button>
  </form>
  <p class="mt-3 text-sm text-muted">
    UI only. Connect this form to Resend, Buttondown, or your preferred service.
  </p>
</section>
