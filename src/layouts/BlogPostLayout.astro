---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate, getPostSlug, type BlogPost } from '@/utils/posts';

interface Props {
  post: BlogPost;
  readingTime: string;
}

const { post, readingTime } = Astro.props;
const { title, description, pubDate, updatedDate, tags, image } = post.data;
---

<BaseLayout title={`${title} | Bachapin Blog`} description={description} image={image}>
  <article class="px-6 py-16 sm:px-8 sm:py-20" data-pagefind-body>
    <header class="mx-auto max-w-prose border-b border-divider pb-10">
      <a href="/blog" class="font-mono text-sm text-muted hover:text-accent">/blog</a>
      <h1 class="mt-6 text-[2.5rem] font-semibold leading-tight text-text">{title}</h1>
      <p class="mt-6 text-lg leading-8 text-muted">{description}</p>
      <div class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-2 font-mono text-sm text-muted">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        <span aria-hidden="true">/</span>
        <span>{readingTime}</span>
        {updatedDate && (
          <>
            <span aria-hidden="true">/</span>
            <span>Updated {formatDate(updatedDate)}</span>
          </>
        )}
      </div>
      {tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2" aria-label="Post tags">
          {tags.map((tag) => (
            <a
              href={`/blog?tag=${encodeURIComponent(tag)}`}
              class="border border-divider px-3 py-1 font-mono text-sm text-muted hover:border-accent hover:text-accent"
            >
              #{tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="prose-content mx-auto mt-12">
      <slot />
    </div>

    <footer class="mx-auto mt-16 max-w-prose border-t border-divider pt-8">
      <a href="/blog" class="font-mono text-sm text-muted hover:text-accent">
        Back to all posts
      </a>
    </footer>
  </article>
</BaseLayout>
